{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist-ts",
    "types": ["node"]
  },
  "include": [
    "electron.vite.config.ts",
    "electron/**/*.ts"
  ]
}
